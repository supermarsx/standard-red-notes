{
  "name": "@standard-red-notes/websocket-gateway",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Self-hosted WebSocket push gateway for Standard Red Notes (replaces AWS API Gateway WebSocket push).",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "e2e": "node e2e/realtime.e2e.mjs && node e2e/collab.e2e.mjs && node e2e/collab-yjs.e2e.mjs",
    "e2e:browser": "node e2e/browser.e2e.mjs",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,json,md}\" \"test/**/*.{ts,tsx,js,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,json,md}\" \"test/**/*.{ts,tsx,js,json,md}\""
  },
  "dependencies": {
    "@aws-sdk/client-sqs": "^3.1068.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^25.9.1",
    "@types/ws": "^8.5.13",
    "playwright": "^1.60.0",
    "prettier": "^3.8.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8",
    "y-protocols": "^1.0.6",
    "yjs": "^13.6.18"
  }
}
