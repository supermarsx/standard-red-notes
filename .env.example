# =============================================================================
# Standard Red Notes - environment configuration (EXAMPLE / placeholders only)
#
# DO NOT use these values as-is. Run the setup script to generate a real .env
# with securely-generated secrets:
#
#   macOS / Linux:  ./scripts/setup.sh
#   Windows:        ./scripts/setup.ps1
#
# The real .env is git-ignored. Never commit it - it contains secrets.
# Every value marked CHANGE-ME below must be replaced with a 64-char hex string
# (32 random bytes), e.g. `openssl rand -hex 32`.
# =============================================================================

# ----- Host ports (published on the host machine) ----------------------------
APP_PORT=3001
SERVER_PORT=3000
FILES_PORT=3125
WEBSOCKET_PORT=3106

# ----- Database (MariaDB) ----------------------------------------------------
MYSQL_DATABASE=standard_notes_db
MYSQL_USER=std_notes_user
MYSQL_PASSWORD=CHANGE-ME-random-hex-32
MYSQL_ROOT_PASSWORD=CHANGE-ME-random-hex-32

# ----- Required server secrets (the stack will not start without these) ------
# 64-char hex (32 bytes). The encryption key MUST be exactly 32 bytes of hex.
AUTH_JWT_SECRET=CHANGE-ME-random-hex-32
AUTH_SERVER_ENCRYPTION_SERVER_KEY=CHANGE-ME-random-hex-32
VALET_TOKEN_SECRET=CHANGE-ME-random-hex-32

# Pseudo key-params seed. Auto-generated by the container if unset, but then it
# changes on every restart; pin it here so login key-params stay stable.
AUTH_SERVER_PSEUDO_KEY_PARAMS_KEY=CHANGE-ME-random-hex-32

# ----- Realtime websocket gateway --------------------------------------------
# Shared secrets between the server and the websocket-gateway. Must match.
WEBSOCKET_GATEWAY_INTERNAL_SECRET=CHANGE-ME-random-hex-32
WEB_SOCKET_CONNECTION_TOKEN_SECRET=CHANGE-ME-random-hex-32

# ----- Domain / cookies / origins --------------------------------------------
# Empty COOKIE_DOMAIN => host-only cookie (works on localhost / any bare host/IP).
# For an HTTPS deployment behind a domain, set COOKIE_DOMAIN to your domain and
# COOKIE_SECURE=true so the auth cookie is only sent over HTTPS.
COOKIE_DOMAIN=
COOKIE_SECURE=false
PUBLIC_FILES_SERVER_URL=http://localhost:3125

# ----- Reverse proxy ---------------------------------------------------------
# Controls express's "trust proxy" so req.secure / req.protocol / req.ip honor
# the X-Forwarded-Proto / X-Forwarded-For headers your proxy sets. The default
# (applied by docker-compose.yml when unset) trusts a proxy on loopback or a
# private/Docker network, which covers the usual compose-behind-a-proxy setup
# while still allowing direct, non-proxied access. Override only if your proxy
# sits on a public IP (then use a CSV of its IPs/subnets, a hop count, or "true").
# When serving over HTTPS through the proxy, ALSO set COOKIE_SECURE=true (and
# COOKIE_DOMAIN). See docs/self-hosting.md "Running behind a reverse proxy".
# TRUST_PROXY=loopback, linklocal, uniquelocal

# WebAuthn / hardware-key (U2F) relying party. Should match where the app is served.
AUTH_SERVER_U2F_RELYING_PARTY_ID=localhost
AUTH_SERVER_U2F_EXPECTED_ORIGIN=http://localhost:3001,http://localhost

# ----- Admin -----------------------------------------------------------------
# Comma-separated emails granted the in-app Admin panel and /admin endpoints.
ADMIN_EMAILS=

# =============================================================================
# Optional settings (uncomment and edit as needed). Defaults are applied by
# docker-compose.yml when these are left unset.
# =============================================================================
# LOG_LEVEL=info
# COOKIE_SAME_SITE=Lax
# COOKIE_PARTITIONED=false
#
# STANDARD_RED_FEATURES_MODE=included
# STANDARD_RED_ENTITLEMENT_MODE=included
# STANDARD_RED_FULL_FEATURE_FILE_UPLOAD_BYTES_LIMIT=-1
#
# REVISIONS_RETENTION_DAYS=0
# REVISIONS_MAX_COUNT_PER_ITEM=0
#
# AUTH_SERVER_U2F_RELYING_PARTY_NAME=Standard Red Notes
#
# ASSISTANT_ANTHROPIC_API_KEY=
# ASSISTANT_OPENAI_API_KEY=
# ASSISTANT_OPENAI_BASE_URL=
# ASSISTANT_OPENAI_MODEL=
# ASSISTANT_OLLAMA_URL=
# ASSISTANT_DEFAULT_PROVIDER=
# ASSISTANT_DEFAULT_MODEL=
# Per-user, per-day AI assistant REQUEST cap enforced by the server proxy (not a
# token cap). 0 / unset = unlimited (opt-in). Per-user overrides come from the
# AI_REQUEST_LIMIT user setting. When set, the web footer surfaces "AI: used / limit"
# with a near-limit warning color; the proxy refuses requests past the cap (HTTP 429).
# ASSISTANT_DAILY_REQUEST_LIMIT=0
#
# STANDARD_RED_NOTES_EMAIL=
# STANDARD_RED_NOTES_PASSWORD=
# STANDARD_RED_NOTES_ALLOW_WRITES=0
#
# ----- Optional server-wide shared access key ("obfuscation gate") -----------
# OFF by default (leave SHARED_SERVER_ACCESS_KEY empty/unset => zero behavior
# change). When set, the api-gateway refuses requests that do not present this
# key in the X-Shared-Server-Key header. This is OBFUSCATION / access-gating for
# a self-hosted instance so a casual scanner who finds the server cannot use it
# without the key. It is NOT end-to-end security and NOT a user password -- real
# confidentiality of note content is still the client-side E2E encryption. Enter
# the same key in each client under Preferences > Security > Server Access Key.
# Mode selects what is gated: "all" (every request; the /healthcheck path is
# always exempt so the container stays healthy) or "registration" (only new
# account sign-ups, leaving existing users unaffected).
# SHARED_SERVER_ACCESS_KEY=CHANGE-ME-random-hex-32
# SHARED_SERVER_ACCESS_KEY_MODE=all
