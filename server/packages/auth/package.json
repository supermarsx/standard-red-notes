{
  "name": "@standardnotes/auth-server",
  "version": "1.178.7",
  "engines": {
    "node": ">=22.0.0"
  },
  "description": "Auth Server for SN",
  "main": "dist/src/index.js",
  "typings": "dist/src/index.d.ts",
  "author": "Karol Sójko <karol@standardnotes.com>",
  "license": "AGPL-3.0-or-later",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "git@github.com:standardnotes/server.git",
    "directory": "packages/auth"
  },
  "scripts": {
    "clean": "rm -fr dist",
    "setup:env": "cp .env.sample .env",
    "build": "tsc --build",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --fix --ext .ts",
    "test": "jest --coverage --no-cache --config=./jest.config.js --maxWorkers=2",
    "start": "yarn node dist/bin/server.js",
    "worker": "yarn node dist/bin/worker.js",
    "cleanup": "yarn node dist/bin/cleanup.js",
    "stats": "yarn node dist/bin/stats.js",
    "daily-backup:email": "yarn node dist/bin/backup.js daily",
    "user-email-backup": "yarn node dist/bin/user_email_backup.js",
    "weekly-backup:email": "yarn node dist/bin/backup.js weekly",
    "content-recalculation": "yarn node dist/bin/content.js",
    "typeorm": "typeorm-ts-node-commonjs",
    "migrate": "yarn build && yarn typeorm migration:run -d dist/src/Bootstrap/MigrationsDataSource.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1057.0",
    "@aws-sdk/client-sns": "^3.1057.0",
    "@aws-sdk/client-sqs": "^3.1057.0",
    "@cbor-extract/cbor-extract-linux-arm64": "^2.2.2",
    "@cbor-extract/cbor-extract-linux-x64": "^2.2.2",
    "@grpc/grpc-js": "1.14.4",
    "@simplewebauthn/server": "^13.3.1",
    "@standardnotes/api": "^1.26.95",
    "@standardnotes/common": "workspace:*",
    "@standardnotes/domain-core": "workspace:^",
    "@standardnotes/domain-events": "workspace:*",
    "@standardnotes/domain-events-infra": "workspace:*",
    "@standardnotes/features": "^1.61.3",
    "@standardnotes/grpc": "workspace:^",
    "@standardnotes/predicates": "workspace:*",
    "@standardnotes/responses": "^1.13.56",
    "@standardnotes/security": "workspace:*",
    "@standardnotes/settings": "workspace:*",
    "@standardnotes/sncrypto-common": "^1.13.8",
    "@standardnotes/sncrypto-node": "workspace:*",
    "@standardnotes/time": "workspace:*",
    "@types/semver": "^7.7.1",
    "agentkeepalive": "^4.6.0",
    "axios": "^1.16.1",
    "bcryptjs": "3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "2.8.6",
    "dayjs": "^1.11.21",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "inversify": "^6.2.2",
    "inversify-express-utils": "^6.5.0",
    "ioredis": "^5.11.0",
    "mysql2": "^3.22.4",
    "otplib": "^13.4.1",
    "prettyjson": "^1.2.5",
    "reflect-metadata": "^0.2.2",
    "semver": "^7.8.1",
    "sqlite3": "^6.0.1",
    "typeorm": "^0.3.27",
    "ua-parser-js": "^2.0.10",
    "uuid": "^11.1.0",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/cookie-parser": "^1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/ioredis": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.9.1",
    "@types/prettyjson": "^0.0.33",
    "@types/uuid": "^11.0.0",
    "jest": "^30.4.2",
    "jest-util": "^30.2.0",
    "ts-jest": "^29.4.11",
    "typescript": "^6.0.3"
  }
}
