{
  "name": "@standardnotes/syncing-server",
  "version": "1.136.6",
  "engines": {
    "node": ">=22.0.0"
  },
  "description": "Syncing Server",
  "main": "dist/src/index.js",
  "typings": "dist/src/index.d.ts",
  "repository": {
    "type": "git",
    "url": "git@github.com:standardnotes/server.git",
    "directory": "packages/syncing-server"
  },
  "author": "Karol Sójko <karol@standardnotes.com>",
  "license": "AGPL-3.0-or-later",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "clean": "rm -fr dist",
    "setup:env": "cp .env.sample .env",
    "build": "tsc --build",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "test": "jest --coverage --no-cache --config=./jest.config.js --maxWorkers=2",
    "start": "yarn node dist/bin/server.js",
    "worker": "yarn node dist/bin/worker.js",
    "content-size": "yarn node dist/bin/content.js",
    "migrate": "yarn clean && yarn build && yarn typeorm migration:run -d dist/src/Bootstrap/MigrationsDataSource.js"
  },
  "dependencies": {
    "@aws-sdk/client-cloudwatch": "^3.1057.0",
    "@aws-sdk/client-s3": "^3.1057.0",
    "@aws-sdk/client-sns": "^3.1057.0",
    "@aws-sdk/client-sqs": "^3.1057.0",
    "@grpc/grpc-js": "1.14.4",
    "@standardnotes/api": "^1.26.95",
    "@standardnotes/common": "workspace:*",
    "@standardnotes/domain-core": "workspace:^",
    "@standardnotes/domain-events": "workspace:*",
    "@standardnotes/domain-events-infra": "workspace:*",
    "@standardnotes/grpc": "workspace:^",
    "@standardnotes/responses": "^1.13.56",
    "@standardnotes/security": "workspace:*",
    "@standardnotes/settings": "workspace:*",
    "@standardnotes/sncrypto-node": "workspace:*",
    "@standardnotes/time": "workspace:*",
    "cors": "2.8.6",
    "dotenv": "^17.4.2",
    "express": "^4.21.2",
    "helmet": "^7.2.0",
    "inversify": "^6.2.2",
    "inversify-express-utils": "^6.5.0",
    "ioredis": "^5.11.0",
    "jsonwebtoken": "^9.0.3",
    "mysql2": "^3.22.4",
    "prettyjson": "^1.2.5",
    "reflect-metadata": "^0.2.2",
    "semver": "^7.8.1",
    "sqlite3": "^5.1.7",
    "typeorm": "^0.3.27",
    "ua-parser-js": "^1.0.40",
    "uuid": "^9.0.1",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/dotenv": "^8.2.3",
    "@types/express": "^4.17.21",
    "@types/ioredis": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.9.1",
    "@types/prettyjson": "^0.0.33",
    "@types/semver": "^7.7.1",
    "@types/ua-parser-js": "^0.7.39",
    "@types/uuid": "^9.0.8",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.11",
    "typescript": "^6.0.3"
  }
}
