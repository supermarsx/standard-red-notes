{
  "name": "@standardnotes/revisions-server",
  "version": "1.51.20",
  "engines": {
    "node": ">=22.0.0"
  },
  "description": "Revisions Server",
  "main": "dist/src/index.js",
  "typings": "dist/src/index.d.ts",
  "repository": {
    "type": "git",
    "url": "git@github.com:standardnotes/server.git",
    "directory": "packages/revisions"
  },
  "author": "Karol Sójko <karol@standardnotes.com>",
  "license": "AGPL-3.0-or-later",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "clean": "rm -fr dist",
    "setup:env": "cp .env.sample .env",
    "build": "tsc --build",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "test": "jest --coverage --no-cache --config=./jest.config.js --maxWorkers=2",
    "start": "yarn node dist/bin/server.js",
    "worker": "yarn node dist/bin/worker.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1057.0",
    "@aws-sdk/client-sns": "^3.1057.0",
    "@aws-sdk/client-sqs": "^3.1057.0",
    "@standardnotes/api": "^1.26.95",
    "@standardnotes/common": "workspace:^",
    "@standardnotes/domain-core": "workspace:^",
    "@standardnotes/domain-events": "workspace:*",
    "@standardnotes/domain-events-infra": "workspace:*",
    "@standardnotes/responses": "^1.13.56",
    "@standardnotes/security": "workspace:^",
    "@standardnotes/time": "workspace:^",
    "cors": "2.8.6",
    "dotenv": "^17.4.2",
    "express": "^4.21.2",
    "inversify": "^6.2.2",
    "inversify-express-utils": "^6.5.0",
    "ioredis": "^5.11.0",
    "mysql2": "^3.22.4",
    "reflect-metadata": "^0.2.2",
    "sqlite3": "^5.1.7",
    "typeorm": "^0.3.27",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/dotenv": "^8.2.3",
    "@types/express": "^4.17.21",
    "@types/ioredis": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^25.9.1",
    "jest": "^29.7.0",
    "jest-util": "^29.7.0",
    "ts-jest": "^29.4.11",
    "typescript": "^6.0.3"
  }
}
