{
  "name": "@standardnotes/files-server",
  "version": "1.38.4",
  "engines": {
    "node": ">=22.0.0"
  },
  "description": "Standard Notes Files Server",
  "main": "dist/src/index.js",
  "typings": "dist/src/index.d.ts",
  "repository": {
    "type": "git",
    "url": "git@github.com:standardnotes/server.git",
    "directory": "packages/files"
  },
  "authors": [
    "Karol Sójko <karol@standardnotes.com>"
  ],
  "license": "AGPL-3.0-or-later",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "clean": "rm -fr dist",
    "setup:env": "cp .env.sample .env",
    "build": "tsc --build",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --fix --ext .ts",
    "test": "jest --coverage --no-cache --config=./jest.config.js --maxWorkers=2",
    "start": "yarn node dist/bin/server.js",
    "worker": "yarn node dist/bin/worker.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1057.0",
    "@aws-sdk/client-sns": "^3.1057.0",
    "@aws-sdk/client-sqs": "^3.1057.0",
    "@standardnotes/domain-core": "workspace:^",
    "@standardnotes/domain-events": "workspace:*",
    "@standardnotes/domain-events-infra": "workspace:*",
    "@standardnotes/security": "workspace:*",
    "@standardnotes/sncrypto-common": "^1.13.8",
    "@standardnotes/sncrypto-node": "workspace:*",
    "@standardnotes/time": "workspace:*",
    "connect-busboy": "^1.0.0",
    "cors": "^2.8.6",
    "dayjs": "^1.11.21",
    "dotenv": "^17.4.2",
    "express": "^4.21.2",
    "express-robots-txt": "^1.0.0",
    "express-winston": "^4.2.0",
    "helmet": "^7.2.0",
    "inversify": "^6.2.2",
    "inversify-express-utils": "^6.5.0",
    "ioredis": "^5.11.0",
    "jsonwebtoken": "^9.0.3",
    "prettyjson": "^1.2.5",
    "reflect-metadata": "^0.2.2",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@types/connect-busboy": "^1.0.3",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/ioredis": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.9.1",
    "@types/prettyjson": "^0.0.33",
    "@types/uuid": "^9.0.8",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.11",
    "typescript": "^6.0.3",
    "uuid": "^9.0.1"
  }
}
