MODE=microservice # microservice | home-server | self-hosted
LOG_LEVEL=debug
NODE_ENV=development
VERSION=development

PORT=3000

SYNCING_SERVER_JS_URL=http://syncing_server_js:3000
SYNCING_SERVER_GRPC_URL=http://syncing_server_js:50052
AUTH_SERVER_URL=http://auth:3000
AUTH_SERVER_GRPC_URL=http://auth:50051
WEB_SOCKET_SERVER_URL=http://websockets:3000
PAYMENTS_SERVER_URL=http://payments:3000
FILES_SERVER_URL=http://files:3000
REVISIONS_SERVER_URL=http://revisions:3000
EMAIL_SERVER_URL=http://email:3000

HTTP_CALL_TIMEOUT=60000

AUTH_JWT_SECRET=auth_jwt_secret

CACHE_TYPE=redis
REDIS_URL=redis://cache

# (Optional) Caching Cross Service Tokens
CROSS_SERVICE_TOKEN_CACHE_TTL=

# ---- Assistant LLM proxy (server-held provider credentials) ----
# Anthropic
ASSISTANT_ANTHROPIC_API_KEY=
# OpenAI-compatible (OpenAI, LM Studio, Ollama, OpenRouter, custom)
ASSISTANT_OPENAI_API_KEY=
ASSISTANT_OPENAI_BASE_URL=
ASSISTANT_OPENAI_MODEL=
# Native Ollama (/api/chat)
ASSISTANT_OLLAMA_URL=
# Defaults / limits
ASSISTANT_DEFAULT_PROVIDER=
ASSISTANT_DEFAULT_MODEL=
# Per-user, per-day AI REQUEST cap (not tokens). 0/unset = unlimited (opt-in).
# Per-user override via the AI_REQUEST_LIMIT setting. Enforced on /v1/assistant/stream
# (HTTP 429 past the cap) and reported by GET /v1/assistant/usage as { used, limit }.
ASSISTANT_DAILY_REQUEST_LIMIT=
# Comma-separated speech-to-text model ids advertised to clients for the audio
# recorder's transcription model picker (e.g. whisper-1,gpt-4o-transcribe). Empty
# = clients fall back to a free-text model field. Served at the public, read-only
# GET /v1/assistant/transcription/models endpoint.
TRANSCRIPTION_MODELS=

# ---- OpenAI Codex / ChatGPT subscription mode (OPT-IN) ----
# Set to 'subscription' to authenticate the OpenAI-compatible provider with a
# ChatGPT/Codex subscription access token instead of an API key. Leave unset or
# 'api-key' to keep the default OpenAI API-key behavior (nothing changes).
ASSISTANT_OPENAI_AUTH_MODE=
# The ChatGPT/Codex subscription bearer token (OAuth access token / session token
# from a ChatGPT account login). See provider docs for how to obtain it.
ASSISTANT_OPENAI_SUBSCRIPTION_TOKEN=
# Base URL for the ChatGPT/Codex backend. UNVERIFIED default placeholder:
# https://chatgpt.com/backend-api/codex — confirm against a live subscription.
ASSISTANT_OPENAI_SUBSCRIPTION_BASE_URL=
# Optional ChatGPT account id (sent as the ChatGPT-Account-Id header).
ASSISTANT_OPENAI_ACCOUNT_ID=
# Optional OpenAI-Beta header value the Codex backend may require.
ASSISTANT_OPENAI_BETA=
# Optional extra headers (JSON object or comma-separated 'Key: Value' list),
# applied to every upstream request in both auth modes.
ASSISTANT_OPENAI_EXTRA_HEADERS=

# ---- Publish note to GitHub (OPT-IN, server-mediated) ----
# Authenticated endpoint: POST /v1/integrations/github/publish
# Body: { token (GitHub PAT), owner, repo, branch?, path, content, message? }
# The gateway forwards the note (Markdown) + PAT to the GitHub Contents API. No
# server configuration is required — the PAT is supplied by the user per request
# and is never persisted or logged. The feature is inert until a user invokes it.
# PRIVACY: this sends DECRYPTED note content to the server and to GitHub (stored
# unencrypted), removing end-to-end encryption for the published copy.

# ---- Web proxy for the browser AI agent (fetch + search) ----
# Authenticated endpoints (same session auth as the assistant proxy):
#   POST /v1/web/fetch  { url }    -> { status, contentType, title, text }
#   POST /v1/web/search { query }  -> { results: [{ title, url, snippet }], error? }
# /v1/web/fetch retrieves a page server-side (no CORS) and returns its readable
# plain text (scripts/styles/markup stripped, capped at WEB_FETCH_MAX_CHARS).
# An SSRF guard rejects non-http(s) schemes and private/loopback/link-local/
# metadata hosts (localhost, 127/8, 169.254/16 incl. 169.254.169.254, 10/8,
# 172.16/12, 192.168/16, ::1, *.internal/*.local), resolving DNS names first.
#
# Search backend is selected by SEARCH_PROVIDER. Supported values:
#   searxng -> GET SEARCH_API_URL?q=<query>&format=json  (SearXNG JSON API;
#              SEARCH_API_KEY optional, sent as Bearer if set)
#   brave   -> GET SEARCH_API_URL?q=<query> with X-Subscription-Token: SEARCH_API_KEY
#              (Brave Search API; default URL https://api.search.brave.com/res/v1/web/search)
#   serper  -> POST SEARCH_API_URL { q } with X-API-KEY: SEARCH_API_KEY
#              (Serper.dev Google SERP; URL https://google.serper.dev/search)
# If SEARCH_PROVIDER / SEARCH_API_URL are unset, /v1/web/search returns HTTP 200
# with { results: [], error: 'web search not configured' } (never a 500).
SEARCH_PROVIDER=
SEARCH_API_URL=
SEARCH_API_KEY=
# Optional caps (defaults: 100000 chars, 15000 ms).
WEB_FETCH_MAX_CHARS=
WEB_FETCH_TIMEOUT_MS=
