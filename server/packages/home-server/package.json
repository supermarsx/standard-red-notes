    "start": "yarn node dist/bin/server.js"
  },
  "dependencies": {
    "@standardnotes/api-gateway": "workspace:^",
    "@standardnotes/auth-server": "workspace:^",
    "@standardnotes/domain-core": "workspace:^",
    "@standardnotes/domain-events-infra": "workspace:^",
    "@standardnotes/files-server": "workspace:^",
    "@standardnotes/revisions-server": "workspace:^",
    "@standardnotes/syncing-server": "workspace:^",
    "cookie-parser": "^1.4.7",
    "cors": "2.8.6",
    "dotenv": "^17.4.2",
    "express": "^4.21.2",
    "express-robots-txt": "^1.0.0",
    "helmet": "^7.2.0",
    "inversify": "^6.2.2",
    "inversify-express-utils": "^6.5.0",
    "reflect-metadata": "^0.2.2",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "typescript": "^6.0.3"
  }
}
