{
  "name": "standard-red-notes",
  "version": "0.1.0",
  "private": true,
  "description": "Standard Red Notes monorepo for the app, server, and MCP bridge.",
  "license": "AGPL-3.0-only",
  "packageManager": "yarn@4.15.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "workspaces": [
    "mcp",
    "openclaw",
    "websocket-gateway"
  ],
  "scripts": {
    "build": "yarn build:mcp && yarn build:openclaw && yarn build:app && yarn build:server",
    "build:app": "cd app && yarn build:all",
    "build:mcp": "yarn workspace @standard-red-notes/mcp build",
    "build:openclaw": "yarn workspace @standard-red-notes/openclaw build",
    "build:server": "cd server && yarn build",
    "check": "yarn typecheck && yarn lint && yarn format:check && yarn test",
    "deps:audit": "yarn deps:audit:app && yarn deps:audit:server",
    "deps:audit:app": "npx npm-check-updates@22.2.1 --workspaces --root --format group --target latest --cwd app",
    "deps:audit:server": "npx npm-check-updates@22.2.1 --workspaces --root --format group --target latest --cwd server",
    "docker:config": "docker compose config",
    "docker:down": "docker compose down",
    "docker:up": "docker compose up --build",
    "format": "yarn format:mcp && yarn format:openclaw && yarn format:app && yarn format:server",
    "format:app": "cd app && yarn format",
    "format:check": "yarn format:check:mcp && yarn format:check:openclaw && yarn format:check:app && yarn format:check:server",
    "format:check:app": "cd app && yarn format:check",
    "format:check:mcp": "yarn workspace @standard-red-notes/mcp format:check",
    "format:check:openclaw": "yarn workspace @standard-red-notes/openclaw format:check",
    "format:check:server": "cd server && yarn format:check",
    "format:mcp": "yarn workspace @standard-red-notes/mcp format",
    "format:openclaw": "yarn workspace @standard-red-notes/openclaw format",
    "format:server": "cd server && yarn format",
    "lint": "yarn lint:mcp && yarn lint:openclaw && yarn lint:app && yarn lint:server",
    "lint:app": "cd app && yarn lint",
    "lint:mcp": "yarn workspace @standard-red-notes/mcp typecheck",
    "lint:openclaw": "yarn workspace @standard-red-notes/openclaw typecheck",
    "lint:server": "cd server && yarn lint",
    "start:mcp": "yarn workspace @standard-red-notes/mcp start",
    "start:openclaw": "yarn workspace @standard-red-notes/openclaw start",
    "test": "yarn test:openclaw && yarn test:app && yarn test:server",
    "test:app": "cd app && yarn test",
    "test:openclaw": "yarn workspace @standard-red-notes/openclaw test",
    "test:server": "cd server && yarn test",
    "typecheck": "yarn typecheck:mcp && yarn typecheck:openclaw",
    "typecheck:mcp": "yarn workspace @standard-red-notes/mcp typecheck",
    "typecheck:openclaw": "yarn workspace @standard-red-notes/openclaw typecheck"
  },
  "devDependencies": {
    "npm-check-updates": "^22.2.1",
    "turbo": "^2.9.16"
  }
}
