{
  "name": "@standardnotes/snjs",
  "version": "2.211.7",
  "repository": {
    "type": "git",
    "url": "https://github.com/standardnotes/app",
    "directory": "packages/snjs"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "main": "dist/snjs.js",
  "author": "Standard Notes",
  "types": "dist/@types",
  "files": [
    "dist",
    "mocha",
    "e2e-server.js"
  ],
  "bin": "e2e-server.js",
  "license": "AGPL-3.0",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "start": "webpack -w --config webpack.dev.js",
    "start:test-server": "yarn node e2e-server.js",
    "clean": "rm -fr dist",
    "prebuild": "yarn clean",
    "build": "yarn tsc && webpack --config webpack.prod.js",
    "watch": "webpack --config webpack.prod.js --watch",
    "docs": "jsdoc -c jsdoc.json",
    "tsc": "tsc --project lib/tsconfig.json && tscpaths -p lib/tsconfig.json -s lib -o dist/@types",
    "lint": "yarn lint:eslint lib",
    "lint:eslint": "eslint --ext .ts lib/",
    "lint:fix": "eslint --fix --ext .ts lib/",
    "lint:tsc": "tsc --noEmit --emitDeclarationOnly false --project lib/tsconfig.json",
    "test": "jest",
    "test:debug": "node --inspect-brk node_modules/.bin/jest --runInBand"
  },
  "devDependencies": {
    "@babel/core": "*",
    "@babel/preset-env": "*",
    "@standardnotes/api": "workspace:*",
    "@standardnotes/common": "^1.52.4",
    "@standardnotes/domain-core": "^1.41.3",
    "@standardnotes/domain-events": "^2.141.1",
    "@standardnotes/encryption": "workspace:*",
    "@standardnotes/features": "workspace:*",
    "@standardnotes/files": "workspace:*",
    "@standardnotes/models": "workspace:*",
    "@standardnotes/responses": "workspace:*",
    "@standardnotes/services": "workspace:*",
    "@standardnotes/settings": "^1.23.4",
    "@standardnotes/sncrypto-common": "workspace:*",
    "@standardnotes/sncrypto-web": "workspace:*",
    "@standardnotes/utils": "workspace:*",
    "@types/crypto-js": "^4.2.2",
    "@types/jest": "^29.5.14",
    "@types/jsdom": "^28.0.3",
    "@types/libsodium-wrappers": "^0.8.2",
    "@types/semver": "^7.7.1",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "babel-jest": "^30.4.1",
    "babel-loader": "^10.1.1",
    "circular-dependency-plugin": "^5.2.2",
    "crypto-js": "^4.2.0",
    "docdash": "^2.0.2",
    "dom-storage": "^2.1.0",
    "eslint": "^8.57.0",
    "eslint-plugin-prettier": "*",
    "exports-loader": "^5.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.4.1",
    "jsdom": "^29.1.1",
    "libsodium-wrappers": "0.8.4",
    "nock": "^14.0.15",
    "otplib": "^13.4.1",
    "reflect-metadata": "^0.2.2",
    "script-loader": "^0.7.2",
    "semver": "^7.8.1",
    "ts-jest": "^29.4.11",
    "ts-loader": "^9.6.0",
    "ts-node": "^10.9.2",
    "tscpaths": "0.0.9",
    "typescript": "6.0.3",
    "uuid": "^11.1.0",
    "webpack": "^5.107.2",
    "webpack-cli": "^7.0.3",
    "webpack-merge": "^6.0.1"
  },
  "dependencies": {
    "connect": "^3.7.0",
    "serve-static": "^2.2.1"
  }
}
