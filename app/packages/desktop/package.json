{
  "name": "@standardnotes/desktop",
  "main": "./app/dist/index.js",
  "version": "3.110.192",
  "license": "AGPL-3.0",
  "author": "Standard Red Notes.",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git://github.com/supermarsx/standard-red-notes",
    "directory": "app/packages/desktop"
  },
  "workspaces": {
    "packages": [
      "app"
    ]
  },
  "scripts": {
    "build:remove-unpacked": "rimraf dist/{linux-*,mac,win-*}",
    "build": "yarn run webpack --config desktop.webpack.prod.js",
    "clean:build": "rimraf app/dist/",
    "clean:tests": "rimraf test/data/tmp/",
    "dev": "NODE_ENV=development webpack --config desktop.webpack.dev.js --watch",
    "format": "prettier --write .",
    "lint:eslint": "eslint app/index.ts app/application.ts app/javascripts/**/*.ts",
    "lint:formatting": "prettier --check app",
    "lint": "yarn lint:formatting && yarn lint:eslint app && yarn tsc",
    "tsc": "tsc --noEmit",
    "package": "yarn build && cd app && yarn run forge:package",
    "make": "yarn build && cd app && yarn run forge:make",
    "publish": "yarn build && cd app && yarn run forge:publish",
    "start": "electron ./app --enable-logging --icon _icon/icon.png",
    "ava": "rimraf test/data/tmp && ava --serial",
    "rebuild:keytar": "yarn app/node_modules/keytar build ",
    "rebuild:home-server": "electron-rebuild -f -w @standardnotes/home-server -m ./app"
  },
  "installConfig": {
    "hoistingLimits": "workspaces"
  },
  "dependencies": {
    "@electron/remote": "^2.1.3",
    "@standardnotes/domain-core": "^1.41.3",
    "@standardnotes/electron-clear-data": "1.1.1",
    "@standardnotes/snjs": "workspace:*",
    "@standardnotes/utils": "workspace:*",
    "@standardnotes/web": "workspace:*",
    "axios": "^1.18.0",
    "compare-versions": "^6.1.1",
    "decrypt": "github:standardnotes/decrypt#master",
    "dotenv": "^17.4.2",
    "electron": "42.4.1",
    "electron-log": "^5.4.4",
    "fs-extra": "^11.3.5",
    "lodash": "^4.18.1",
    "mime-types": "^3.0.2",
    "mobx": "^6.16.1",
    "update-electron-app": "^3.2.0"
  },
  "devDependencies": {
    "@babel/core": "*",
    "@babel/preset-env": "*",
    "@electron/notarize": "^3.1.1",
    "@electron/rebuild": "4.0.4",
    "@types/fs-extra": "^11.0.4",
    "@types/lodash": "^4.17.24",
    "@types/mime-types": "^3.0.1",
    "@types/node": "25",
    "@types/proxyquire": "^1.3.31",
    "@types/yauzl": "^2.10.3",
    "ava": "^8.0.1",
    "babel-loader": "^10.1.1",
    "copy-webpack-plugin": "^14.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-promise": "^7.3.0",
    "file-loader": "^6.2.0",
    "mime-types": "^3.0.2",
    "prettier": "*",
    "proxyquire": "^2.1.3",
    "rimraf": "^6.1.3",
    "terser-webpack-plugin": "^5.6.1",
    "ts-loader": "^9.6.2",
    "ts-node": "^10.9.2",
    "typescript": "6.0.3",
    "webpack": "^5.107.2",
    "webpack-merge": "^6.0.1"
  },
  "ava": {
    "concurrency": 0,
    "extensions": [
      "ts"
    ],
    "files": [
      "test/*.spec.ts"
    ],
    "require": [
      "ts-node/register/transpile-only"
    ],
    "verbose": true
  },
  "pre-push": [
    "lint"
  ]
}
