{
  "compilerOptions": {
    "target": "esnext",
    "module": "ES2020",
    "moduleResolution": "node",
    "allowJs": true,
    "strict": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "declaration": true,
    "rootDir": "./src",
    "outDir": "./dist",
    "inlineSourceMap": true,
    "types": [
      "node"
    ],
    "typeRoots": [
      "node_modules/@types",
      "typings"
    ],
    "ignoreDeprecations": "6.0"
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "dist",
    "test/**/*"
  ]
}
