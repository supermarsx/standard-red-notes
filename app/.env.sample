PORT=3001

# Default sync server the web client loads with. Leave pointing at your own
# server — a self-hosted deployment should NOT default to api.standardnotes.com.
# In Docker this is set via SYNC_SERVER (see docker-compose.yml); for `yarn dev`
# it defaults to your local server below.
DEFAULT_SYNC_SERVER=http://localhost:3000

# Subscription/marketing endpoints. This fork has no paid tier, so they point
# nowhere by default (the app also overrides these to about:blank at runtime).
DASHBOARD_URL=about:blank
PLANS_URL=about:blank
PURCHASE_URL=about:blank
